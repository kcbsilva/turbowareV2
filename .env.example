# ── Database ──────────────────────────────────────────────────────────────────
# Same Supabase project as turboisp-api. Turboware billing tables use schema "turboware"
# so they do not collide with TurboISP public tables (e.g. invoices).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# TurboISP tenant provisioning — same project/password as DATABASE_URL above.
TURBOISP_DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Wildcard domain served by Vercel — no DNS API required
TURBOISP_DOMAIN="turboisp.app"
# Where new tenants sign in after signup (TurboISP React app)
TURBOISP_APP_URL="https://turboisp.app"
NEXT_PUBLIC_TURBOISP_APP_URL="https://turboisp.app"
# Comma-separated origins allowed to call /api/signup directly (optional if proxied via React app)
SIGNUP_CORS_ORIGINS="https://turboisp.app,http://localhost:5173"
# Optional fallback when TURBOISP_DATABASE_URL is unreachable (same Go API as turboisp-react BACKEND_ROUTE)
TURBOISP_API_URL="https://your-go-api.example.com"
# Set to "false" to disable /api/signup
PUBLIC_SIGNUP_ENABLED=true

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-key"
ADMIN_PASSWORD="change-me"

# ── Client Desktop API ────────────────────────────────────────────────────────
CLIENT_API_KEY=""

# ── Vercel Cron ───────────────────────────────────────────────────────────────
CRON_SECRET=""

# ── Asaas (Brazilian payment gateway — Pix, Boleto, Credit Card) ──────────────
# Get your key at https://www.asaas.com → Configurações → Integrações
ASAAS_API_KEY=              # $aact_... (sandbox) or $aact_... (production)
ASAAS_SANDBOX=true          # Set to "false" in production

# ── Stripe (International clients) ───────────────────────────────────────────
# Get your keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=          # sk_test_... (test) or sk_live_... (production)
STRIPE_PUBLISHABLE_KEY=     # pk_test_... or pk_live_...
# Webhook secret — generate with: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# In production, copy the signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=      # whsec_...

# ── App URL (used for Stripe success/cancel redirect + verification emails) ───
APP_URL=https://app.turboisp.com.br
NEXT_PUBLIC_APP_URL=https://app.turboisp.com.br

# ── SMTP (verification emails, client/admin password resets) ─────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TurbowareV2 <noreply@yourdomain.com>

# ── reCAPTCHA v3 (TurboISP signup) ────────────────────────────────────────────
# Site key is public (NEXT_PUBLIC_*); secret verifies tokens server-side.
# Leave RECAPTCHA_SECRET_KEY empty in local dev to skip verification.
RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
