# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://turboware:password@localhost:5432/turboware"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-key"
ADMIN_PASSWORD="change-me"

# ── Client Desktop API ────────────────────────────────────────────────────────
# TurboISP supports two activation modes:
#
# MODE 1 — License key (legacy, kept for backward compatibility):
#   POST /api/client/validate  { key, hardwareId? }
#   POST /api/client/activate  { key, hardwareId, label? }
#   Requires Authorization: Bearer <CLIENT_API_KEY> when set.
#   Leave empty to disable the bearer check during local dev / gradual rollout.
CLIENT_API_KEY=""
#
# MODE 2 — Portal credentials (new, recommended):
#   POST /api/client/auth/activate  { cnpj, password, hardwareId }
#     → Authenticates with portal credentials, returns plan + permissions.
#       Call once on first install (or when credentials change).
#   POST /api/client/auth/validate  { cnpj, hardwareId }
#     → Periodic re-validation on startup. No password needed after first
#       activation — uses hardwareId as proof of prior activation.
#   No shared secret required — the operator's CNPJ + password IS the secret.

# ── Vercel Cron ───────────────────────────────────────────────────────────────
# Secret injected by Vercel into the Authorization header on cron invocations.
# Set this in your Vercel project environment variables and Vercel will
# automatically pass it as: Authorization: Bearer <CRON_SECRET>
# Leave empty to disable the check during local dev.
CRON_SECRET=""

# ── TurboISP DB (separate Supabase project — tenant provisioning) ─────────────
# Connection string for the TurboISP Supabase project (different from TurbowareV2's DB).
# Used by /api/register to INSERT rows into tenants and system_users on signup.
TURBOISP_DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"
# Wildcard domain served by Vercel — no DNS API required
TURBOISP_DOMAIN="turboisp.app"
# Where new tenants sign in after signup (TurboISP React app)
TURBOISP_APP_URL="https://turboisp.app"
NEXT_PUBLIC_TURBOISP_APP_URL="https://turboisp.app"
# Comma-separated origins allowed to call /api/signup directly (optional if proxied via React app)
SIGNUP_CORS_ORIGINS="https://turboisp.app,http://localhost:5173"
# Set to "false" to disable /api/signup
PUBLIC_SIGNUP_ENABLED=true

# ── Asaas (Brazilian payment gateway — Pix, Boleto, Credit Card) ──────────────
# Get your key at https://www.asaas.com → Configurações → Integrações
ASAAS_API_KEY=              # $aact_... (sandbox) or $aact_... (production)
ASAAS_SANDBOX=true          # Set to "false" in production

# ── Stripe (International clients) ───────────────────────────────────────────
# Get your keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=          # sk_test_... (test) or sk_live_... (production)
STRIPE_PUBLISHABLE_KEY=     # pk_test_... or pk_live_...
# Webhook secret — generate with: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# In production, copy the signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=      # whsec_...

# ── App URL (used for Stripe success/cancel redirect + verification emails) ───
APP_URL=https://app.turboisp.com.br
NEXT_PUBLIC_APP_URL=https://app.turboisp.com.br

# ── SMTP (verification emails, client/admin password resets) ─────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TurbowareV2 <noreply@yourdomain.com>

# ── reCAPTCHA v3 (TurboISP signup) ────────────────────────────────────────────
# Site key is public (NEXT_PUBLIC_*); secret verifies tokens server-side.
# Leave RECAPTCHA_SECRET_KEY empty in local dev to skip verification.
RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
