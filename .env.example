# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://turboware:password@localhost:5432/turboware"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-key"
ADMIN_PASSWORD="change-me"

# ── Client Desktop API ────────────────────────────────────────────────────────
# Shared secret for /api/client/validate and /api/client/activate.
# Clients must send: Authorization: Bearer <CLIENT_API_KEY>
# Leave empty to disable the check during local dev / gradual rollout.
CLIENT_API_KEY=""

# ── Vercel Cron ───────────────────────────────────────────────────────────────
# Secret injected by Vercel into the Authorization header on cron invocations.
# Set this in your Vercel project environment variables and Vercel will
# automatically pass it as: Authorization: Bearer <CRON_SECRET>
# Leave empty to disable the check during local dev.
CRON_SECRET=""

# ── DigitalOcean DNS ──────────────────────────────────────────────────────────
DO_API_TOKEN="your_digitalocean_token"
DO_DOMAIN="turboisp.app"
MAIN_VPS_IP="your_vps_public_ip"
